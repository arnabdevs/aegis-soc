# ── AEGIS SOC Engine v4 — Environment Variables ─────────────────────────────
# Copy to .env for local dev. On Render set in Dashboard → Environment.
# NEVER commit a real .env to GitHub.

# Auto-generated by render.yaml — no action needed
SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHAR_STRING

# Your Vercel frontend URL — used to lock CORS in production
FRONTEND_URL=https://your-app.vercel.app

# Your Render backend URL — used in email verification links
BACKEND_URL=https://aegis-soc-v4.onrender.com

# ── UPGRADE 2: Supabase PostgreSQL ──────────────────────────────────────────
# Get from: supabase.com → project → Settings → Database → Connection string
# Use the "URI" format (postgres://...)
# Leave blank to use in-memory DB (local dev without Supabase)
SUPABASE_DB_URL=

# ── UPGRADE 4: Upstash Redis ─────────────────────────────────────────────────
# Get from: upstash.com → Redis → Connect → .env → REDIS_URL
# Leave blank to use in-memory rate limiting
REDIS_URL=

# ── Security APIs ─────────────────────────────────────────────────────────────
# VirusTotal  — free 500 req/day  →  https://www.virustotal.com/gui/my-apikey
VIRUSTOTAL_API_KEY=

# AbuseIPDB   — free 1000 req/day →  https://www.abuseipdb.com/account/api
ABUSEIPDB_API_KEY=

# URLScan.io  — free 1000 req/day →  https://urlscan.io/user/signup
URLSCAN_API_KEY=

# HIBP        — ~$3.50/mo         →  https://haveibeenpwned.com/API/Key
HIBP_API_KEY=

# AlienVault OTX — free (optional) → https://otx.alienvault.com
OTX_API_KEY=

# ── Notifications ─────────────────────────────────────────────────────────────
# Gmail + App Password (NOT your login password)
# Create: myaccount.google.com → Security → 2-Step → App passwords
MAIL_USERNAME=you@gmail.com
MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Telegram bot — create with @BotFather, get chat ID from @userinfobot
TELEGRAM_BOT_TOKEN=

# ── AEGIS Active Defence (Cloudflare) ────────────────────────────────────────
# Clients provide their OWN Cloudflare token + Zone ID when connecting a domain.
# You do NOT need a global Cloudflare key here.
# Each client's credentials are stored securely in their profile.
# See: /api/protect/connect endpoint
